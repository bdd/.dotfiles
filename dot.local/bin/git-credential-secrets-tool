#!/usr/bin/env bash
set -euo pipefail

usage() {
  exec >&2
  (( $# > 0 )) && printf "%s\n" "$@" ""
  cat <<EOF
usage: $(basename "${BASH_SOURCE[0]}") [-u USERNAME ] [SECRET_GROUP]:SECRET_NAME

Enable for the repo:
  git config credential.helper "secrets-tool [-u USERNAME] [SECRET_GROUP]:SECRET_NAME
EOF
  exit $#
}

while getopts "u:h" opt; do
  case "${opt}" in
    u) username="${OPTARG}" ;;
    h) usage ;;
    \?) usage "Unknown flag: -${OPTARG}" >&2 ;;
    :) usage "-${OPTARG} requires an argument" ;;
  esac
done

shift $((OPTIND-1))

if ! [[ ${1-} =~ ^[A-Z0-9_-]*:[A-Z0-9_-]+$ ]]; then
  usage "Need first arg as 'SECRET_GROUP:SECRET_NAME' or ':SECRET_NAME'"
fi

IFS=':' read -r secret_group secret_name <<<"${1}"
shift

# Only respond to "get" requests.
[[ "${1-}" == "get" ]] || exit 0

# Read the credential request from stdin.
declare -A input
while IFS='=' read -r key value; do
  [[ -n ${key} ]] && input["${key}"]="${value}"
done

if [[ -z ${secret_group-} ]]; then
  password=$(secrets_tool get "${secret_name}")
else
  password=$(secrets_tool get_from_group "${secret_name}" "${secret_group}")
fi

cat <<EOF
protocol=${input[protocol]}
host=${input[host]}
username=${username-${USER}}
password=${password}
EOF

exit 0
