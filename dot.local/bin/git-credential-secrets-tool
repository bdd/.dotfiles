#!/usr/bin/env bash
set -euo pipefail

# Usage: git config credential.helper "secrets-tool [ -u USERNAME ] [SECRET_GROUP]:SECRET_NAME"
while getopts "u:" opt; do
  case "${opt}" in
    u) username="${OPTARG}" ;;
    \?) echo "Unknown flag: -${OPTARG}" >&2; exit 1 ;;
    :) echo "-${OPTARG} requires an argument" >&2; exit 1 ;;
  esac
done

shift $((OPTIND - 1))

if ! [[ ${1-} =~ ^[A-Z0-9_-]*:[A-Z0-9_-]+$ ]]; then
  echo "Need first arg as 'SECRET_GROUP:SECRET_NAME' or ':SECRET_NAME'" >&2
  exit 1
fi

IFS=":" read -r secret_group secret_name <<<"${1}"
shift

# Only respond to "get" requests.
[[ "${1-}" == "get" ]] || exit 0

# Read the credential request from stdin.
declare -A input
while IFS='=' read -r key value; do
  [[ -n ${key} ]] && input["${key}"]="${value}"
done

if [[ -z ${secret_group-} ]]; then
  password=$(secrets_tool get "${secret_name}")
else
  password=$(secrets_tool get_from_group "${secret_name}" "${secret_group}")
fi

cat <<EOF
protocol=${input[protocol]}
host=${input[host]}
username=${username-${USER}}
password=${password}
EOF

exit 0
